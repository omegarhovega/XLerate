{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch",
    "test:core": "vitest run",
    "test:core:watch": "vitest",
    "typecheck:core": "tsc -p tsconfig.vitest.json --noEmit",
    "typecheck:harness": "tsc -p tsconfig.harness.json --noEmit",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src",
    "lint:harness": "eslint src/adapters src/services tests/excelPortFake.spec.ts tests/switchSign.contract.spec.ts",
    "ci:all": "npm run typecheck:core && npm run typecheck:harness && npm run lint:harness && npm run arch:check && npm run test:core && npm run build:dev",
    "start:wsl": "webpack serve --mode development",
    "stop:wsl": "sh -c 'fuser -k 3000/tcp 2>/dev/null || true'",
    "start:web:manual": "webpack serve --mode development",
    "icons": "node scripts/build-icons.mjs"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "regenerator-runtime": "^0.14.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.15"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-typescript": "^7.23.3",
    "@types/node": "^25.3.2",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "dependency-cruiser": "^16.10.4",
    "eslint-plugin-office-addins": "^4.0.3",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "sharp": "^0.34.5",
    "source-map-loader": "^5.0.0",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.1.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
